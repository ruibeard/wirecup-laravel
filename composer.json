{
    "name": "ruibeard/wirecup-laravel",
    "description": "Expose Wirecup .cup mockups inside Laravel for LLM and developer preview workflows.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/ruibeard/wirecup-laravel",
    "keywords": [
        "laravel",
        "wirecup",
        "wireframes"
    ],
    "authors": [
        {
            "name": "Rui Almeida"
        }
    ],
    "support": {
        "issues": "https://github.com/ruibeard/wirecup-laravel/issues",
        "source": "https://github.com/ruibeard/wirecup-laravel"
    },
    "require": {
        "php": "^8.2",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Ruibeard\\LaravelWirecup\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruibeard\\LaravelWirecup\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ruibeard\\LaravelWirecup\\WirecupServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
